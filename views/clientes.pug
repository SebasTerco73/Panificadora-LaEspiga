doctype html
html
  head
    title Clientes
    link(rel="stylesheet" href="/styles/styles.css")
  body
    h1 Lista de clientes

    //- Formulario inline para crear/editar
    form#formCliente
      input#inputId(type="hidden")

      label Nombre:
      input#inputNombre(type="text" name="nombre" required)

      label Email:
      input#inputEmail(type="email" name="email" required)

      label Teléfono:
      input#inputTelefono(type="text" name="telefono" required)

      label Dirección:
      input#inputDireccion(type="text" name="direccion" required)

      label Tipo:
      select#inputTipo(name="tipo")
        option(value="minorista") Minorista
        option(value="mayorista") Mayorista
        option(value="franquicia") Franquicia

      button(type="submit" class="btn") Guardar
      button#btnCancelar(class="btn secundario" type="button" style="display:none") Cancelar

    hr

    table
      thead
        tr
          th Nombre
          th Email
          th Teléfono
          th Dirección
          th Tipo
          th Acciones
      tbody#tablaClientes

    a.btn.secundario(href="/") Volver

    script(src="/js/clientes.js")